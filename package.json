{
  "name": "atlas-root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "description": "ATLAS MVP-0: local Knowledge Compiler and Artificial Mind Format",
  "scripts": {
    "build": "tsc -b packages/types packages/graph packages/privacy packages/frameworks packages/migration packages/memory packages/security packages/tools packages/agents packages/context packages/compiler packages/kernel packages/mcp packages/reasoning packages/cognition packages/world-model packages/runtime packages/cli apps/playground apps/codex-assistant",
    "clean": "tsc -b --clean packages/types packages/graph packages/privacy packages/frameworks packages/migration packages/memory packages/security packages/tools packages/agents packages/context packages/compiler packages/kernel packages/mcp packages/reasoning packages/cognition packages/world-model packages/runtime packages/cli apps/playground apps/codex-assistant",
    "test": "vitest run --dir packages",
    "playground": "node apps/playground/dist/index.js",
    "playground:scenario": "node apps/playground/dist/index.js --scenario",
    "codex:assistant": "node apps/codex-assistant/dist/index.js",
    "codex:ask": "node apps/codex-assistant/dist/index.js ask",
    "codex:remember": "node apps/codex-assistant/dist/index.js remember",
    "codex:status": "node apps/codex-assistant/dist/index.js status",
    "codex:scenario": "node apps/codex-assistant/dist/index.js scenario",
    "memory:init": "node packages/cli/dist/index.js memory init",
    "memory:add": "node packages/cli/dist/index.js memory add",
    "memory:search": "node packages/cli/dist/index.js memory search",
    "memory:retrieve": "node packages/cli/dist/index.js memory retrieve",
    "memory:lesson": "node packages/cli/dist/index.js memory lesson",
    "memory:stats": "node packages/cli/dist/index.js memory stats",
    "memory:privacy-check": "node packages/cli/dist/index.js memory privacy-check",
    "memory:short:add": "node packages/cli/dist/index.js memory short:add",
    "memory:short:search": "node packages/cli/dist/index.js memory short:search",
    "memory:short:retrieve": "node packages/cli/dist/index.js memory short:retrieve",
    "memory:short:expire": "node packages/cli/dist/index.js memory short:expire",
    "memory:short:cleanup": "node packages/cli/dist/index.js memory short:cleanup",
    "memory:short:promote": "node packages/cli/dist/index.js memory short:promote",
    "memory:context": "node packages/cli/dist/index.js memory context",
    "mind:context": "node packages/cli/dist/index.js mind context",
    "mind:explain": "node packages/cli/dist/index.js mind explain",
    "mind:reflect": "node packages/cli/dist/index.js mind reflect",
    "mind:debug": "node packages/cli/dist/index.js mind debug",
    "actions:list": "node packages/cli/dist/index.js actions list",
    "actions:show": "node packages/cli/dist/index.js actions show",
    "actions:replay": "node packages/cli/dist/index.js actions replay",
    "actions:risks": "node packages/cli/dist/index.js actions risks",
    "framework:detect": "node packages/cli/dist/index.js framework detect",
    "framework:commands": "node packages/cli/dist/index.js framework commands",
    "framework:verify": "node packages/cli/dist/index.js framework verify-plan"
  },
  "devDependencies": {
    "@atlas/types": "workspace:*",
    "@atlas/frameworks": "workspace:*",
    "@types/node": "^22.13.14",
    "lmti": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

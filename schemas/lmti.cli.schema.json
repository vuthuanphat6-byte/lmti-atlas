{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyno.software/lmti/schemas/lmti.cli.schema.json",
  "title": "LMTI CLI JSON Boundary Envelope",
  "type": "object",
  "required": ["schemaVersion", "command", "status", "warnings", "errors", "data"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "lmti.cli.v1" },
    "command": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "warn", "blocked", "error"] },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/message" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/message" }
    },
    "data": { "type": "object" }
  },
  "$defs": {
    "message": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "suggestion": { "type": "string", "minLength": 1 }
      }
    }
  }
}
